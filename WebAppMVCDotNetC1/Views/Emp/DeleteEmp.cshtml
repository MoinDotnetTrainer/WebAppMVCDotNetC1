@model WebAppMVCDotNetC1.Models.EmpModel
@{
    ViewData["Title"] = "DeleteEmp";
}



<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow">
                <div class="card-header bg-danger text-white">
                    <h3 class="text-center">Delete Employee</h3>
                </div>

                <div class="card-body">

                    <div class="alert alert-warning">
                        <strong>Are you sure you want to delete this employee?</strong>
                    </div>

                    <dl class="row">
                        <dt class="col-sm-4">Employee ID</dt>
                        <dd class="col-sm-8">@Model.EmpID</dd>

                        <dt class="col-sm-4">Employee Name</dt>
                        <dd class="col-sm-8">@Model.EName</dd>

                        <dt class="col-sm-4">Email</dt>
                        <dd class="col-sm-8">@Model.Email</dd>


                        <dt class="col-sm-4">Date of Birth</dt>
                        <dd class="col-sm-8">@Model.Dob.ToShortDateString()</dd>
                    </dl>

                    <form asp-action="DeleteEmp" method="post">
                        <input type="hidden" asp-for="EmpID" />

                        <button type="submit" class="btn btn-danger">
                            Delete
                        </button>

                        <a asp-action="Index" class="btn btn-secondary">
                            Cancel
                        </a>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>