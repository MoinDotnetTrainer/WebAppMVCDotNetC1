@model IEnumerable<BusinessLogicLayer.Models.Orders>

@{
    ViewData["Title"] = "GetOrders";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<body class="bg-light">

    <a asp-action="AddOrders" asp-controller="OrdersTask">Add Orders</a>
    <div class="container mt-5">

        <div class="card shadow">
            <div class="card-header bg-primary text-white">
                <h3 class="text-center">Orders List</h3>
            </div>

            <div class="card-body">

                <div class="table-responsive">

                    <table class="table table-bordered table-striped table-hover align-middle text-center">

                        <thead class="table-dark">
                            <tr>
                                <th>Order ID</th>
                                <th>Order Name</th>
                                <th>Expiry Date</th>
                                <th>Quantity</th>
                                <th>Actions</th>
                            </tr>
                        </thead>

                        <tbody>


                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @item.OrderID
                                    </td>
                                    <td>
                                        @item.Name
                                    </td>
                                    <td>
                                        @item.ExpiryDate
                                    </td>
                                    <td>
                                        @item.Qty
                                    </td>


                                    @if (this.User.IsInRole("Admin")  && this.User.Identity.IsAuthenticated)
                                    {
                                        <td>
                                            <a asp-action="GetOrdersByID" asp-route-OrderID="@item.OrderID">Get Order By ID</a>|
                                            <a asp-action="EditOrders" asp-route-OrderID="@item.OrderID">Edit</a>|
                                            <a asp-action="DeleteOrders" asp-route-OrderID="@item.OrderID">Delete</a>
                                        </td>
                                    }
                                    <td>

                                    </td>

                                </tr>

                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>

    </div>

    <!-- Bootstrap 5 JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>

