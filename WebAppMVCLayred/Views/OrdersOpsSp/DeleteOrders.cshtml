@model BusinessLogicLayer.Models.Orders

@{
    ViewData["Title"] = "DeleteOrders";
    Layout = "~/Views/Shared/_UserLayout.cshtml";
}



<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">

            <div class="card border-danger shadow">

                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-trash-fill"></i>
                        Delete Order
                    </h3>
                </div>

                <div class="card-body">

                    <div class="alert alert-warning">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <strong>Warning!</strong> Are you sure you want to delete this order?
                    </div>

                    <table class="table table-bordered table-striped">
                        <tbody>

                            <tr>
                                <th width="35%">Order ID</th>
                                <td>@Model.OrderID</td>
                            </tr>

                            <tr>
                                <th> Name</th>
                                <td>@Model.Name</td>
                            </tr>



                            <tr>
                                <th>Quantity</th>
                                <td>@Model.Qty</td>
                            </tr>



                        </tbody>
                    </table>

                    <form asp-action="DeleteOrders" method="post">
                        <input type="hidden" asp-for="OrderID" />

                        <div class="text-end">

                            <a asp-action="getOrders" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i>
                                Cancel
                            </a>

                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-trash-fill"></i>
                                Delete
                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>
    </div>
</div>

